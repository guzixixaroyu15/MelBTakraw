"trainer.scenario.1.title" = "Der Return ist nach einem kurzen Aufschlag instabil.";
"trainer.scenario.1.prompt" = "Du bist der Feeder. Welche Aktion eröffnet das beste Angriffsfeld für dein Team?";
"trainer.scenario.1.option.1" = "Den Ball sauber ans Netz anheben, damit ein kontrollierter Abschluss möglich wird.";
"trainer.scenario.1.option.2" = "Einen überhasteten Schlag beim zweiten Kontakt aus ungünstiger Körperlage erzwingen.";
"trainer.scenario.1.option.3" = "Den Ball ohne Angriffsstruktur nach hinten spielen.";
"trainer.scenario.1.feedback" = "Ein ruhiges Setup schafft einen echten Angriff. Die Aufgabe des Feeders ist es, Chaos in einen verwertbaren Ball zu verwandeln.";
"trainer.scenario.2.title" = "Der Gegner greift nach hohem Zuspiel ständig diagonal an.";
"trainer.scenario.2.prompt" = "Was sollte dein Team tun, bevor der nächste Kontakt kommt?";
"trainer.scenario.2.option.1" = "Tief absinken und den Raum am Netz offen lassen.";
"trainer.scenario.2.option.2" = "Die Abwehr zur Diagonale verschieben und den Konter sofort vorbereiten.";
"trainer.scenario.2.option.3" = "Das Muster ignorieren und nur auf einen Fehler warten.";
"trainer.scenario.2.feedback" = "Tendenzen zu lesen ist Teil von Spitzen-Takraw. Gute Vorpositionierung schafft Rettung und Konterchance zugleich.";
"trainer.scenario.3.title" = "Der Tekong hat zwei Aufschläge in Folge verschlagen.";
"trainer.scenario.3.prompt" = "Was ist die beste Reset-Entscheidung für das Team?";
"trainer.scenario.3.option.1" = "Das Risiko erhöhen und einen Wunderaufschlag erzwingen.";
"trainer.scenario.3.option.2" = "Zu einem stabileren Aufschlag zurückkehren und Rhythmus über Kontrolle neu aufbauen.";
"trainer.scenario.3.option.3" = "Mitten in der Rally ohne Signal oder Vorbereitung die Rollen wechseln.";
"trainer.scenario.3.feedback" = "In Präzisionssportarten kehrt Momentum oft zuerst über Stabilität zurück. Kontrolle baut Vertrauen wieder auf.";
"trainer.scenario.4.title" = "Dein Killer kommt zu spät zum Zuspiel und kann nicht in voller Höhe angreifen.";
"trainer.scenario.4.prompt" = "Was ist die klügste Teamreaktion?";
"trainer.scenario.4.option.1" = "Den Überkopfschlag trotzdem erzwingen, weil der Ball nah am Netz ist.";
"trainer.scenario.4.option.2" = "Die Rally treiben lassen und nur auf einen gegnerischen Fehler hoffen.";
"trainer.scenario.4.option.3" = "Den Ball sicher recyceln und den Angriff im nächsten Muster neu aufbauen.";
"trainer.scenario.4.feedback" = "Top-Teams wissen, wann sie den Abschluss nicht erzwingen dürfen. Neuaufbau ist oft die reifere Entscheidung.";
"trainer.scenario.5.title" = "Dein Team hat schon zwei Kontakte genutzt und der Ball driftet zur Seitenlinie.";
"trainer.scenario.5.prompt" = "Was ist der klügste letzte Kontakt?";
"trainer.scenario.5.option.1" = "Einen kontrollierten, legalen Return spielen und die Rally verlängern.";
"trainer.scenario.5.option.2" = "In Panik mit dem Arm nach dem Ball schlagen.";
