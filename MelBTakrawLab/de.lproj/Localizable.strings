"trainer.scenario.5.feedback" = "Wenn die Kontaktzahl knapp wird, zählt legale Kontrolle mehr als Show.";
"trainer.scenario.6.title" = "Der Gegner liest deinen Feeder und schließt das Netz früh.";
"trainer.scenario.6.prompt" = "Wie sollte dein Team reagieren?";
"trainer.scenario.6.option.1" = "Das gleiche schnelle Zuspiel ohne Tarnung wiederholen.";
"trainer.scenario.6.option.2" = "Einen Abschluss mit geringer Erfolgsquote durch den Block erzwingen.";
"trainer.scenario.6.option.3" = "Mit verzögertem Setup das Timing verschieben und die Bahn neu öffnen.";
"trainer.scenario.6.feedback" = "Rhythmuswechsel ist oft stärker als erzwungene Power.";
"trainer.scenario.7.title" = "Dein Tekong sieht, dass der Rückspieler zu weit nach innen lehnt.";
