"trainer.scenario.1.title" = "The return is unstable after a short serve.";
"trainer.scenario.1.prompt" = "You are the Feeder. What gives your team the highest-quality attack window?";
"trainer.scenario.1.option.1" = "Lift the ball cleanly toward the net for a controlled finishing angle.";
"trainer.scenario.1.option.2" = "Force a rushed second-touch strike from an awkward body position.";
"trainer.scenario.1.option.3" = "Send the ball backward with no attacking structure at all.";
"trainer.scenario.1.feedback" = "A calm setup creates a real attack. The Feeder's job is to turn chaos into a hittable ball.";
"trainer.scenario.2.title" = "The opponent keeps attacking diagonally after a high set.";
"trainer.scenario.2.prompt" = "What should your team do before the next contact arrives?";
"trainer.scenario.2.option.1" = "Drop deep and leave space near the net unprotected.";
"trainer.scenario.2.option.2" = "Shade the defense toward the diagonal and prepare the counter immediately.";
"trainer.scenario.2.option.3" = "Ignore the pattern and wait only for a mistake.";
"trainer.scenario.2.feedback" = "Reading tendencies is part of elite Takraw. Pre-positioning gives you both a save and a counter chance.";
"trainer.scenario.3.title" = "The Tekong has missed two serves in a row.";
"trainer.scenario.3.prompt" = "What is the best reset decision for the team?";
"trainer.scenario.3.option.1" = "Increase risk and chase a miracle serve to recover instantly.";
"trainer.scenario.3.option.2" = "Return to a more stable serve and rebuild rhythm through control.";
"trainer.scenario.3.option.3" = "Swap roles mid-rally without any signal or preparation.";
"trainer.scenario.3.feedback" = "Momentum in precision sports often returns through stability first. Control rebuilds confidence.";
"trainer.scenario.4.title" = "Your Killer is late to the set and cannot attack at full height.";
"trainer.scenario.4.prompt" = "What is the smartest team response?";
"trainer.scenario.4.option.1" = "Force the overhead anyway because the ball is near the net.";
"trainer.scenario.4.option.2" = "Let the rally drift and hope the opponent misses on the next touch.";
"trainer.scenario.4.option.3" = "Recycle the ball safely and rebuild the attack on the next pattern.";
"trainer.scenario.4.feedback" = "Top teams know when not to force the finish. Rebuilding the sequence is often the elite choice.";
"trainer.scenario.5.title" = "Your team used two touches and the ball is drifting too close to the sideline.";
"trainer.scenario.5.prompt" = "What is the smartest final contact?";
"trainer.scenario.5.option.1" = "Send a controlled return high enough to stay legal and extend the rally.";
"trainer.scenario.5.option.2" = "Panic and swing with the arm for extra reach.";
"trainer.scenario.5.option.3" = "Stop moving and let the ball drop untouched.";
"trainer.scenario.5.feedback" = "When touch count is tight, legal control matters more than flash. Staying alive is the right call.";
"trainer.scenario.6.title" = "The opponent reads your Feeder and closes the net early.";
"trainer.scenario.6.prompt" = "How should your side respond to the pressure?";
"trainer.scenario.6.option.1" = "Repeat the same quick set with no disguise.";
"trainer.scenario.6.option.2" = "Rush a low-percentage finish through the block.";
"trainer.scenario.6.option.3" = "Use a delayed setup to shift timing and reopen the lane.";
"trainer.scenario.6.feedback" = "Changing rhythm is often stronger than forcing power. Delay can move the blocker first.";
"trainer.scenario.7.title" = "Your Tekong notices the receiver leaning too far inside.";
"trainer.scenario.7.prompt" = "Which elite-level serve choice creates the highest value?";
"trainer.scenario.7.option.1" = "Serve directly into the receiver's comfort zone.";
"trainer.scenario.7.option.2" = "Target the exposed outside lane and force a reaching first touch.";
"trainer.scenario.7.option.3" = "Slow the action with an intentionally soft fault-risk toss.";
"trainer.scenario.7.feedback" = "Elite Takraw punishes pre-commitment. Attacking the open lane turns reading into advantage.";
"trainer.scenario.8.title" = "The rally turns chaotic near the net after a deflection.";
"trainer.scenario.8.prompt" = "What should the team prioritize in the next split second?";
"trainer.scenario.8.option.1" = "Force a spectacular finish while balance is broken.";
"trainer.scenario.8.option.2" = "Freeze and wait for a whistle.";
"trainer.scenario.8.option.3" = "Re-establish spacing first, then choose the safest playable touch.";
"trainer.scenario.8.feedback" = "In unstable net moments, spacing is survival. Structure creates the next attack.";
"trainer.scenario.9.title" = "Your front pair is rotating late after a deep defensive save.";
"trainer.scenario.9.prompt" = "Which decision protects the sequence best?";
"trainer.scenario.9.option.1" = "Call for a simple reset touch that buys rotation time.";
"trainer.scenario.9.option.2" = "Commit both players to the same attacking lane.";
"trainer.scenario.9.option.3" = "Ignore spacing and jump for a desperate strike.";
"trainer.scenario.9.feedback" = "A late rotation does not always need heroics. A reset touch can be the highest-IQ play.";
