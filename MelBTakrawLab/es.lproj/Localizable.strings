"trainer.scenario.2.option.2" = "Desplazar la defensa hacia la diagonal y preparar el contraataque de inmediato.";
"trainer.scenario.2.option.3" = "Ignorar el patrón y esperar solo un error.";
"trainer.scenario.2.feedback" = "Leer tendencias forma parte del Takraw de élite. La precolocación te da oportunidad de defensa y contraataque.";
"trainer.scenario.3.title" = "El Tekong ha fallado dos saques seguidos.";
"trainer.scenario.3.prompt" = "¿Cuál es la mejor decisión de reinicio para el equipo?";
"trainer.scenario.3.option.1" = "Aumentar el riesgo y buscar un saque milagroso para recuperarse al instante.";
"trainer.scenario.3.option.2" = "Volver a un saque más estable y reconstruir el ritmo mediante el control.";
"trainer.scenario.3.option.3" = "Cambiar roles a mitad del rally sin señal ni preparación.";
"trainer.scenario.3.feedback" = "En los deportes de precisión, el impulso suele volver primero con estabilidad. El control reconstruye la confianza.";
